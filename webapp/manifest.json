{
  "_version": "1.86.0",
  "sap.app": {
    "id": "com.acutaas.gatepassmanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.28.0",
      "toolsId": "c70813f1-4db5-487c-9699-51afb4c97f31"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.149.1",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.tnt": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.acutaas.gatepassmanagement.i18n.i18n"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "com.acutaas.gatepassmanagement.view",
        "controlId": "splitApp",
        "controlAggregation": "detailPages",
        "transition": "slide",
        "async": true
      },
      "routes": [
        { "pattern": "", "name": "default", "target": "dashboard" },
        { "pattern": "dashboard", "name": "dashboard", "target": "dashboard" },
        { "pattern": "manual", "name": "manual", "target": "manual" },
        { "pattern": "reference", "name": "reference", "target": "reference" },
        { "pattern": "change", "name": "change", "target": "change" },
        { "pattern": "display", "name": "display", "target": "display" },
        { "pattern": "approvalReport", "name": "approvalReport", "target": "approvalReport" },
        { "pattern": "detailReport", "name": "detailReport", "target": "detailReport" }
      ],
      "targets": {
        "dashboard": { "viewName": "Dashboard", "viewId": "dashboard" },
        "manual": { "viewName": "ManualGatePass", "viewId": "manual" },
        "reference": { "viewName": "GatePassReference", "viewId": "reference" },
        "change": { "viewName": "ChangeGatePass", "viewId": "change" },
        "display": { "viewName": "DisplayGatePass", "viewId": "display" },
        "approvalReport": { "viewName": "ApprovalReport", "viewId": "approvalReport" },
        "detailReport": { "viewName": "DetailReport", "viewId": "detailReport" }
      }
    },
    "rootView": {
      "viewName": "com.acutaas.gatepassmanagement.view.App",
      "type": "XML",
      "id": "app"
    }
  }
}