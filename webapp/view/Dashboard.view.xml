<mvc:View
    controllerName="com.acutaas.gatepassmanagement.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
>
    <!-- No SplitApp / sidebar here - the shared sidebar lives once in
         App.view.xml. This is just the detail content the router drops
         into splitApp's detailPages when the "dashboard" route is active. -->
    <Page id="mainDashboard" showHeader="false" backgroundDesign="Solid">
        <content>
            <VBox class="sapUiMediumMargin">

                <Title text="Welcome, User" level="H1" titleStyle="H2" class="sapUiTinyMarginBottom" />
                <Text text="Select an option to get started" class="sapUiLargeMarginBottom" />

                <HBox wrap="Wrap">

                    <GenericTile
                        press=".onManualPress"
                        class="customAppTile blueTile sapUiSmallMarginEnd"
                        header="1. Manual Gate Pass"
                        subheader="Create Gate Pass without reference document">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <ImageContent src="sap-icon://add-document" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <GenericTile
                        press=".onReferencePress"
                        class="customAppTile greenTile sapUiSmallMarginEnd"
                        header="2. Gate Pass with Reference Document"
                        subheader="Create Gate Pass using reference document">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <ImageContent src="sap-icon://inspection" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <GenericTile
                        press=".onChangePress"
                        class="customAppTile orangeTile sapUiSmallMarginEnd"
                        header="3. Change Gate Pass"
                        subheader="Modify existing Gate Pass">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <ImageContent src="sap-icon://edit" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <GenericTile
                        press=".onDisplayPress"
                        class="customAppTile purpleTile"
                        header="4. Display Gate Pass"
                        subheader="View existing Gate Pass">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <ImageContent src="sap-icon://show" />
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                </HBox>
            </VBox>
        </content>
    </Page>
</mvc:View>