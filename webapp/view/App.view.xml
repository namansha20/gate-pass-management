<mvc:View
    controllerName="com.acutaas.gatepassmanagement.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:app="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1"
    displayBlock="true"
>
    <SplitApp id="splitApp">
        <masterPages>
            <Page id="sidebarPage" showHeader="false">
                <!-- Changed to use selectionChange on the List instead of individual item press -->
                <List id="sidebarNavigationList" mode="SingleSelectMaster" selectionChange=".onSidebarSelectionChange" class="sapUiSmallMarginTop">
                    <StandardListItem id="navHome" title="Home" icon="sap-icon://home" app:route="dashboard" />

                    <GroupHeaderListItem id="groupGatePass" title="GATE PASS" />
                    <StandardListItem id="navManualGatePass" title="Manual Gate Pass" icon="sap-icon://create-form" app:route="manual" />
                    <StandardListItem id="navGatePassRef" title="Gate Pass with Reference Document" icon="sap-icon://form" app:route="reference" />
                    <StandardListItem id="navChangeGatePass" title="Change Gate Pass" icon="sap-icon://edit" app:route="change" />
                    <StandardListItem id="navDisplayGatePass" title="Display Gate Pass" icon="sap-icon://display" app:route="display" />

                    <GroupHeaderListItem id="groupReports" title="REPORTS" />
                    <StandardListItem id="navApprovalReport" title="Gate Pass Approval Report" icon="sap-icon://manager-insight" app:route="approvalReport" />
                    <StandardListItem id="navDetailReport" title="Gate Pass Detail Report" icon="sap-icon://list" app:route="detailReport" />
                </List>
            </Page>
        </masterPages>

        <detailPages>
            <!-- The router securely drops views here -->
        </detailPages>
    </SplitApp>
</mvc:View>